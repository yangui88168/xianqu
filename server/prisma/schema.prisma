generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  username         String          @unique
  password         String
  nickname         String?
  avatar           String?
  signature        String?
  status           String          @default("offline")
  lastSeen         DateTime?
  createdAt        DateTime        @default(now())

  // 隐私设置
  allowFriendRequest Boolean       @default(true)
  allowSearch        Boolean       @default(true)
  notifyMessage      Boolean       @default(true)
  notifyCall         Boolean       @default(true)
  notifyPost         Boolean       @default(true)

  // 原有关系
  sentMessages     Message[]       @relation("SentMessages")
  receivedMessages Message[]       @relation("ReceivedMessages")
  sentRequests     FriendRequest[] @relation("SentRequests")
  receivedRequests FriendRequest[] @relation("ReceivedRequests")
  friendships      Friendship[]    @relation("UserFriendships")
  friendOf         Friendship[]    @relation("FriendRelation")
  ownedGroups      GroupChat[]
  groupMemberships GroupMember[]
  groupMessages    GroupMessage[]
  exp              UserExp?
  favorites        Favorite[]

  // 动态广场
  posts            StarPost[]
  likes            StarLike[]
  comments         StarComment[]
  followers        Follow[]        @relation("Followers")
  following        Follow[]        @relation("Followings")

  // 黑名单
  blockedUsers     Blocked[]       @relation("Blocker")
  blockedBy        Blocked[]       @relation("Blocked")

  // 签到记录
  signins          UserSignin[]
  // 任务记录
  tasks            UserTask[]
  // 徽章记录
  badges           UserBadge[]

  // 频道订阅系统 (由新增模型反向生成所需的 User 关联字段)
  ownedChannels      Channel[]           @relation("ChannelOwner")
  channelSubscribed  ChannelSubscriber[]
  channelPosts       ChannelPost[]       @relation("ChannelAuthor")
  channelComments    ChannelComment[]

  // 社区系统（新增）
  ownedCommunities   Community[]
}

model Message {
  id           String         @id @default(cuid())
  content      String
  type         String         @default("text")
  senderId     String
  receiverId   String
  status       String         @default("sent")
  replyToId    String?
  deleted      Boolean        @default(false)
  recalled     Boolean        @default(false)
  edited       Boolean        @default(false)
  readAt       DateTime?
  updatedAt    DateTime?
  createdAt    DateTime       @default(now())
  sender       User           @relation("SentMessages", fields: [senderId], references: [id])
  receiver     User           @relation("ReceivedMessages", fields: [receiverId], references: [id])
  offlineQueue OfflineQueue[]
}

model OfflineQueue {
  id        String  @id @default(cuid())
  userId    String
  messageId String
  message   Message @relation(fields: [messageId], references: [id])
}

model Friendship {
  id        String   @id @default(cuid())
  userId    String
  friendId  String
  note      String?
  groupName String?
  createdAt DateTime @default(now())
  user      User     @relation("UserFriendships", fields: [userId], references: [id])
  friend    User     @relation("FriendRelation", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model FriendRequest {
  id        String   @id @default(cuid())
  senderId  String
  receiverId String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  sender    User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver  User     @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model GroupChat {
  id           String         @id @default(cuid())
  name         String
  ownerId      String
  avatar       String?
  announcement String?
  inviteCode   String?        @unique
  createdAt    DateTime       @default(now())
  owner        User           @relation(fields: [ownerId], references: [id])
  members      GroupMember[]
  messages     GroupMessage[]
}

model GroupMember {
  id         String    @id @default(cuid())
  groupId    String
  userId     String
  role       String    @default("member") // owner, admin, member
  mutedUntil DateTime?
  joinedAt   DateTime  @default(now())
  group      GroupChat @relation(fields: [groupId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        String         @id @default(cuid())
  groupId   String
  senderId  String
  content   String
  type      String         @default("text")
  replyToId String?
  deleted   Boolean        @default(false)
  recalled  Boolean        @default(false)
  createdAt DateTime       @default(now())
  group     GroupChat      @relation(fields: [groupId], references: [id])
  sender    User           @relation(fields: [senderId], references: [id])
  replyTo   GroupMessage?  @relation("Replies", fields: [replyToId], references: [id])
  replies   GroupMessage[] @relation("Replies")
}

model UserExp {
  userId String @id
  exp    Int    @default(0)
  level  Int    @default(1)
  user   User   @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  type      String
  targetId  String
  content   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// 动态广场
model StarPost {
  id         String        @id @default(cuid())
  userId     String
  content    String
  imageUrl   String?
  createdAt  DateTime      @default(now())
  permission String        @default("public")
  user       User          @relation(fields: [userId], references: [id])
  likes      StarLike[]
  comments   StarComment[]
}

model StarLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      StarPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model StarComment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  post      StarPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Followings", fields: [followerId], references: [id])
  following   User     @relation("Followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

// 黑名单
model Blocked {
  userId    String
  blockedId String
  createdAt DateTime @default(now())
  user      User     @relation("Blocker", fields: [userId], references: [id])
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id])

  @@id([userId, blockedId])
}

// 用户签到
model UserSignin {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}

// 用户任务
model UserTask {
  id        String   @id @default(cuid())
  userId    String
  taskType  String
  progress  Int      @default(0)
  target    Int      @default(1)
  completed Boolean  @default(false)
  date      DateTime @default(now()) @db.Date
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// 徽章定义
model Badge {
  id          String      @id
  name        String
  description String?
  icon        String?
  condition   String
  userBadges  UserBadge[]
}

// 用户徽章
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

// ==================== 频道与社区系统 ====================

model Community {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime  @default(now())
  owner       User      @relation(fields: [ownerId], references: [id])
  channels    Channel[]
}

model Channel {
  id           String              @id @default(cuid())
  name         String
  description  String?
  ownerId      String
  communityId  String?
  createdAt    DateTime            @default(now())
  owner        User                @relation("ChannelOwner", fields: [ownerId], references: [id])
  community    Community?          @relation(fields: [communityId], references: [id], onDelete: SetNull)
  subscribers  ChannelSubscriber[]
  posts        ChannelPost[]
}

model ChannelSubscriber {
  channelId String
  userId    String
  createdAt DateTime @default(now())
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([channelId, userId])
}

model ChannelPost {
  id          String           @id @default(cuid())
  channelId   String
  authorId    String
  content     String
  imageUrl    String?
  pinned      Boolean          @default(false)
  pollOptions String?
  pollVotes   String?
  createdAt   DateTime         @default(now())
  channel     Channel          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author      User             @relation("ChannelAuthor", fields: [authorId], references: [id])
  comments    ChannelComment[]
}

model ChannelComment {
  id        String      @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime    @default(now())
  post      ChannelPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])
}
